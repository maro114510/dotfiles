{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "memo-search",
  "title": "Memo Search",
  "description": "Search and open Obsidian memo files",
  "icon": "🐣",
  "author": "maro114510",
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Open Memo",
      "description": "Search and open a memo file",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "1.104.5",
    "@raycast/utils": "2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@types/node": "22.13.10",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop"
  }
}

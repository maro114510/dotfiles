  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; cmd=json.load(sys.stdin).get(\\\"command\\\",\\\"\\\"); exit(0 if \\\"git commit\\\" in cmd else 1)\" 2>/dev/null; then staged=$(git diff --cached --name-only --diff-filter=d 2>/dev/null | grep \"\\.go$\"); if [ -n \"$staged\" ]; then echo \"$staged\" | xargs gofmt -w; git add $staged; fi; fi'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },

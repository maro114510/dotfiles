# extended_glob is required for the (Nm-1) glob qualifier below
setopt extended_glob

autoload -Uz compinit
_comp_path="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-${ZSH_VERSION}"
[[ -d "${_comp_path:h}" ]] || mkdir -p "${_comp_path:h}"
# (Nm-1): N=nullglob, m-1=modified within 1 day — array expansion required outside [[...]]
local -a _comp_match=( "${_comp_path}"(Nm-1) )
if (( ${#_comp_match} )); then
  compinit -C -d "$_comp_path"
else
  compinit -d "$_comp_path"
  touch "$_comp_path"
fi
unset _comp_path


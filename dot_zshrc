### fzf history search ###
function fzf-select-history() {
	BUFFER=$(history -n 1 | \
		tail -r | \
		awk '!seen[$0]++' | \
		fzf --height=40% \
			--no-preview \
			--scheme=history \
			--query="$LBUFFER" \
			--prompt="History > ")
	CURSOR=$#BUFFER
	zle reset-prompt
}
zle -N fzf-select-history
bindkey '^r' fzf-select-history


### git-worktree-runner (gtr) ###
_gtr_init="${XDG_CACHE_HOME:-$HOME/.cache}/gtr/init-gtr.zsh"
# `git wt` is initialized via Sheldon. Only initialize optional `git gtr`
# support when the git subcommand is actually available.
if git gtr -h >/dev/null 2>&1; then
  [[ -f "$_gtr_init" ]] || eval "$(git gtr init zsh)" || true
  [[ -f "$_gtr_init" ]] && source "$_gtr_init" 2>/dev/null || true
fi
unset _gtr_init


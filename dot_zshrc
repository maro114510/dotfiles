# Cache invalidation key: real binary mtime. mise reshim does NOT invalidate caches.
_zsh_cache_eval() {
  local name="$1"
  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/eval-cache"
  local cache_file="$cache_dir/$name"
  local real_bin="" mise_base="$HOME/.local/share/mise/installs/$name"

  if [[ -L "$mise_base/latest" ]]; then
    local target
    target=$(readlink "$mise_base/latest")
    target="${target#./}"
    if [[ -x "$mise_base/$target/$name" ]]; then
      real_bin="$mise_base/$target/$name"
    elif [[ -x "$mise_base/$target/bin/$name" ]]; then
      real_bin="$mise_base/$target/bin/$name"
    fi
  fi

  if [[ -z "$real_bin" ]]; then
    real_bin="$(command -v "$name" 2>/dev/null)" || return 0
  fi

  [[ -x "$real_bin" ]] || return 0
  [[ -d "$cache_dir" ]] || mkdir -p "$cache_dir"

  if [[ ! -f "$cache_file" || "$real_bin" -nt "$cache_file" ]]; then
    "$real_bin" "${@:2}" > "$cache_file" 2>/dev/null
    # starship embeds its own path (resolved via PATH) in PROMPT/PROMPT2 at init time.
    # Replace shim path with the real binary so prompt rendering bypasses the shim.
    local shim_path="$HOME/.local/share/mise/shims/$name"
    [[ -f "$shim_path" && -f "$cache_file" ]] && \
      sed -i '' "s|${shim_path}|${real_bin}|g" "$cache_file" 2>/dev/null
  fi
  source "$cache_file"
}

### Sheldon plugin manager ###
_sheldon_load() {
  local cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/eval-cache/sheldon"
  local toml="${XDG_CONFIG_HOME:-$HOME/.config}/sheldon/plugins.toml"
  local lock="${XDG_DATA_HOME:-$HOME/.local/share}/sheldon/plugins.lock"
  [[ -d "${cache:h}" ]] || mkdir -p "${cache:h}"
  if [[ ! -f "$cache" || "$toml" -nt "$cache" || "$lock" -nt "$cache" ]]; then
    sheldon source > "$cache" 2>/dev/null
  fi
  source "$cache"
}
_sheldon_load
unfunction _sheldon_load
